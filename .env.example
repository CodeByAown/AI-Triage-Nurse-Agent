# ─────────────────────────────────────────────
# Neural Hub AI Triage Nurse — Environment
# Copy to .env and fill all values before running
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
APP_ENV=development
APP_NAME="Neural Hub AI Triage Nurse"
APP_VERSION=1.0.0
SECRET_KEY=change-this-to-a-long-random-string-min-64-chars
NEXTAUTH_SECRET=change-this-nextauth-secret-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# ── Database ─────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=neuralhub_triage
POSTGRES_USER=neuralhub
POSTGRES_PASSWORD=change-this-strong-password
DATABASE_URL=postgresql+asyncpg://neuralhub:change-this-strong-password@postgres:5432/neuralhub_triage
DATABASE_URL_SYNC=postgresql://neuralhub:change-this-strong-password@postgres:5432/neuralhub_triage

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379

# ── AI — Anthropic (Primary) ─────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=4096

# ── AI — OpenAI (Fallback) ───────────────────
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o

# ── Auth ──────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ── CORS ──────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Frontend ──────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME="Neural Hub"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Email (SendGrid) ──────────────────────────
SENDGRID_API_KEY=SG.your-key-here
FROM_EMAIL=noreply@neuralhub.ai
FROM_NAME="Neural Hub"

# ── Storage (Cloudflare R2 / AWS S3) ─────────
S3_BUCKET_NAME=neuralhub-triage-reports
S3_REGION=us-east-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_ENDPOINT_URL=https://your-account.r2.cloudflarestorage.com

# ── Monitoring ────────────────────────────────
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
